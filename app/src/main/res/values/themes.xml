<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- メインアプリ用 (Compose を使うため NoActionBar) -->
    <style name="Theme.Scombzwidgets" parent="android:Theme.Material.Light.NoActionBar"/>

    <!-- ログイン画面用 (WebView + ネイティブView のため ActionBar あり) -->
    <style name="Theme.Scombzwidgets.Login" parent="android:Theme.Material.Light">
        <item name="android:colorPrimary">#B03A2E</item>
        <item name="android:colorPrimaryDark">#922B21</item>
        <item name="android:colorAccent">#1A73E8</item>
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:actionBarStyle">@style/ScombzActionBar</item>
    </style>

    <style name="ScombzActionBar" parent="android:Widget.Material.ActionBar.Solid">
        <item name="android:background">#B03A2E</item>
        <item name="android:titleTextStyle">@style/ScombzActionBarTitle</item>
    </style>

    <style name="ScombzActionBarTitle" parent="android:TextAppearance.Material.Widget.ActionBar.Title">
        <item name="android:textColor">#FFFFFF</item>
    </style>
</resources>
